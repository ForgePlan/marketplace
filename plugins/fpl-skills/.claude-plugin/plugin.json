  "keywords": [
    "forgeplan",
    "workflow",
    "engineering",
    "research",
    "audit",
    "sprint",
    "diagnose",
    "refine",
    "autorun",
    "bootstrap",
    "methodology"
  ],
  "category": "developer-tools",
  "requires": {
    "cli": [
      {
        "name": "forgeplan",
        "optional": false
      }
    ],
    "mcp": [],
    "plugins": []
  },
  "supersedes": {
    "dev-toolkit": "<=1.6.1"
  },
  "components": {
    "commands": [],
    "agents": ["dev-advisor"],
    "skills": [
      "audit",
      "autorun",
      "bootstrap",
      "briefing",
      "build",
      "diagnose",
      "do",
      "forge-report",
      "fpl-init",
      "refine",
      "research",
      "restore",
      "rfc",
      "setup",
      "sprint",
      "team"
    ],
    "hooks": [
      "SessionStart",
